{
  "name": "@hipster/sb-utils",
  "version": "0.0.21",
  "description": "Different, sometimes useful Storybook utilities",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/yannbf/sb-utils/tree/main/libs/sb-utils",
  "bugs": {
    "url": "https://github.com/yannbf/sb-utils/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yannbf/sb-utils.git"
  },
  "author": "Yann Braga <yannbf@gmail.com>",
  "files": [
    "dist"
  ],
  "main": "./dist/bin.mjs",
  "module": "./dist/bin.mjs",
  "types": "./dist/bin.d.mts",
  "bin": "./dist/bin.mjs",
  "exports": {
    "./bin": "./dist/bin.mjs",
    "./uninstall": {
      "types": "./dist/commands/uninstall.d.mts",
      "default": "./dist/commands/uninstall.mjs"
    },
    "./event-logger": {
      "types": "./dist/commands/event-logger.d.mts",
      "default": "./dist/commands/event-logger.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown && vite build",
    "build:dashboard": "vite build",
    "build:cli": "tsdown",
    "dev:dashboard": "vite",
    "dev:cli": "tsdown --watch",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "pretest:e2e": "pnpm run build",
    "run": "jiti src/bin.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/dashboard/tsconfig.json",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@antfu/ni": "^24.3.0",
    "@clack/prompts": "^1.2.0",
    "@hono/node-server": "^1.14.1",
    "commander": "^14.0.2",
    "hono": "^4.7.10",
    "std-env": "^4.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@preact/preset-vite": "^2.10.5",
    "@preact/signals": "^2.9.0",
    "@types/node": "^24.10.1",
    "bumpp": "^10.3.1",
    "jiti": "^2.6.1",
    "preact": "^10.29.1",
    "tsdown": "^0.16.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.0.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
